---
const { variant = 'default' } = Astro.props;
const beehiivFormUrl = 'https://subscribe-forms.beehiiv.com/c6aa4383-73db-44bb-b068-9cae541012be';
---

<div class={`email-signup email-signup--${variant}`}>
  <div class="email-signup-inner">
    {variant === 'post-end' ? (
      <>
        <p class="email-signup-eyebrow">Stay in the loop</p>
        <h3 class="email-signup-heading">Get new posts straight to your inbox</h3>
        <p class="email-signup-text">
          I write about ecosystem marketing, creator-led growth, and what actually works in SaaS. No spam, no fluff, just the stuff I wish someone had told me earlier.
        </p>
      </>
    ) : (
      <>
        <p class="email-signup-eyebrow">Newsletter</p>
        <h3 class="email-signup-heading">Ideas on growth that actually stick</h3>
        <p class="email-signup-text">
          One email when I publish something new. Ecosystem marketing, creator strategies, and the thinking behind SaaS growth, from someone who&apos;s built it, not just studied it.
        </p>
      </>
    )}
    <div class="email-signup-actions">
      <a
        href={beehiivFormUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="email-signup-btn"
        aria-label="Subscribe on Beehiiv (opens in new tab)"
      >
        Subscribe <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <p class="email-signup-note">
      Opens the hosted Beehiiv signup form in a new tab.
    </p>
  </div>
</div>

<style>
  .email-signup {
    border-top: 1px solid var(--gray-200);
  }

  .email-signup--default {
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-200);
    padding: 4rem 0;
  }

  .email-signup--post-end {
    background: var(--gray-50);
    padding: 2.5rem;
    margin-top: 1rem;
    border: 1px solid var(--gray-200);
  }

  .email-signup-inner {
    max-width: var(--content-width, 720px);
    margin: 0 auto;
  }

  .email-signup--default .email-signup-inner {
    padding: 0 2rem;
  }

  .email-signup-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .email-signup-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .email-signup-text {
    font-size: 0.95rem;
    color: var(--gray-600);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 520px;
  }

  .email-signup-actions {
    display: flex;
  }

  .email-signup-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-sans);
    background: var(--black);
    color: var(--white);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .email-signup-btn:hover {
    background: var(--accent-light);
  }

  .email-signup-note {
    font-size: 0.75rem;
    color: var(--gray-500);
    margin-top: 0.75rem;
  }

  .email-signup-btn:hover .arrow {
    transform: translateX(4px);
  }

  .email-signup-btn .arrow {
    display: inline-block;
    transition: transform 0.25s ease;
    text-underline-offset: 0.12em;
  }

  @media (max-width: 640px) {
    .email-signup--default {
      padding: 3rem 0;
    }

    .email-signup--post-end {
      padding: 1.5rem;
    }

    .email-signup--default .email-signup-inner {
      padding: 0 1.25rem;
    }

    .email-signup-actions {
      display: block;
    }

    .email-signup-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
