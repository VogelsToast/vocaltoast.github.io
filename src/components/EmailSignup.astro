---
const { variant = 'default' } = Astro.props;
// variant: 'default' (standalone section), 'post-end' (after blog posts), 'inline' (compact)
---

<div class={`email-signup email-signup--${variant}`}>
  <div class="email-signup-inner">
    {variant === 'post-end' ? (
      <p class="email-signup-eyebrow">Stay in the loop</p>
      <h3 class="email-signup-heading">Get new posts straight to your inbox</h3>
      <p class="email-signup-text">
        I write about ecosystem marketing, creator-led growth, and what actually works in SaaS. No spam, no fluff — just the stuff I wish someone had told me earlier.
      </p>
    ) : (
      <p class="email-signup-eyebrow">Newsletter</p>
      <h3 class="email-signup-heading">Ideas on growth that actually stick</h3>
      <p class="email-signup-text">
        One email when I publish something new. Ecosystem marketing, creator strategies, and the thinking behind SaaS growth — from someone who's built it, not just studied it.
      </p>
    )}
    <form
      class="email-signup-form"
      action="https://app.beehiiv.com/subscribe"
      method="POST"
      data-beehiiv-form
    >
      <!-- Replace pub_05214f1a-0069-4e3a-b588-1783c224ed8a with your Beehiiv publication ID -->
      <input type="hidden" name="publication_id" value="pub_05214f1a-0069-4e3a-b588-1783c224ed8a" />
      <div class="email-signup-row">
        <input
          type="email"
          name="email"
          placeholder="Your email address"
          required
          class="email-signup-input"
          aria-label="Email address"
        />
        <button type="submit" class="email-signup-btn">Subscribe</button>
      </div>
      <p class="email-signup-note">No spam. Unsubscribe anytime.</p>
    </form>
  </div>
</div>

<style>
  .email-signup {
    border-top: 1px solid var(--gray-200);
  }

  .email-signup--default {
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-200);
    padding: 4rem 0;
  }

  .email-signup--post-end {
    background: var(--gray-50);
    padding: 2.5rem;
    margin-top: 1rem;
    border: 1px solid var(--gray-200);
  }

  .email-signup--inline {
    background: transparent;
    border: none;
    padding: 2rem 0;
  }

  .email-signup-inner {
    max-width: var(--content-width, 720px);
    margin: 0 auto;
  }

  .email-signup--default .email-signup-inner {
    padding: 0 2rem;
  }

  .email-signup-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .email-signup-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .email-signup-text {
    font-size: 0.95rem;
    color: var(--gray-600);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 480px;
  }

  .email-signup-row {
    display: flex;
    gap: 0.5rem;
    max-width: 440px;
  }

  .email-signup-input {
    flex: 1;
    padding: 0.8rem 1rem;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    border: 1px solid var(--gray-200);
    background: var(--white);
    color: var(--black);
    outline: none;
    transition: border-color 0.2s;
  }

  .email-signup-input:focus {
    border-color: var(--accent);
  }

  .email-signup-input::placeholder {
    color: var(--gray-500);
  }

  .email-signup-btn {
    padding: 0.8rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-sans);
    background: var(--black);
    color: var(--white);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .email-signup-btn:hover {
    background: var(--accent-light);
  }

  .email-signup-note {
    font-size: 0.75rem;
    color: var(--gray-500);
    margin-top: 0.6rem;
  }

  @media (max-width: 480px) {
    .email-signup-row {
      flex-direction: column;
    }

    .email-signup-btn {
      width: 100%;
    }
  }
</style>
