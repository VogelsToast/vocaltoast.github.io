---
const { variant = 'default' } = Astro.props;
const kitFormUid = '41974a9f46';
const kitEmbedScriptUrl = 'https://zac-culpan.kit.com/41974a9f46/index.js';
---

<div class={`email-signup email-signup--${variant}`}>
  <div class="email-signup-inner">
    {variant === 'post-end' ? (
      <>
        <p class="email-signup-eyebrow">Stay in the loop</p>
        <h3 class="email-signup-heading">Get new posts straight to your inbox</h3>
        <p class="email-signup-text">
          I write about ecosystem marketing, creator-led growth, and what actually works in SaaS. No spam, no fluff, just the stuff I wish someone had told me earlier.
        </p>
      </>
    ) : (
      <>
        <p class="email-signup-eyebrow">Newsletter</p>
        <h3 class="email-signup-heading">Ideas on growth that actually stick</h3>
        <p class="email-signup-text">
          One email when I publish something new. Ecosystem marketing, creator strategies, and the thinking behind SaaS growth, from someone who&apos;s built it, not just studied it.
        </p>
      </>
    )}
    <div class="email-signup-form-wrap">
      <script is:inline async data-uid={kitFormUid} src={kitEmbedScriptUrl}></script>
    </div>
    <p class="email-signup-note">No spam. Unsubscribe anytime.</p>
  </div>
</div>

<style>
  .email-signup {
    border-top: 1px solid var(--gray-200);
  }

  .email-signup--default {
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-200);
    padding: 4rem 0;
  }

  .email-signup--post-end {
    background: var(--gray-50);
    padding: 2.5rem;
    margin-top: 1rem;
    border: 1px solid var(--gray-200);
  }

  .email-signup-inner {
    max-width: var(--content-width, 720px);
    margin: 0 auto;
  }

  .email-signup--default .email-signup-inner {
    padding: 0 2rem;
  }

  .email-signup-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .email-signup-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .email-signup-text {
    font-size: 0.95rem;
    color: var(--gray-600);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 520px;
  }

  .email-signup-form-wrap {
    max-width: 600px;
  }

  .email-signup-note {
    font-size: 0.75rem;
    color: var(--gray-500);
    margin-top: 0.6rem;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46']) {
    max-width: 600px !important;
    margin: 0 !important;
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] > div[data-style='full']) {
    display: block !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-column:first-child),
  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-guarantee),
  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-background) {
    display: none !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-column:last-child) {
    padding: 0 !important;
    background: transparent !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-alert) {
    list-style: none !important;
    margin: 0 0 0.85rem !important;
    padding: 0 !important;
    font-size: 0.85rem !important;
    line-height: 1.5 !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-alert-success) {
    color: var(--accent) !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-alert-error) {
    color: #b42318 !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-fields) {
    display: flex !important;
    flex-wrap: nowrap !important;
    gap: 0.75rem !important;
    align-items: stretch !important;
    margin: 0 !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-field) {
    flex: 1 1 0 !important;
    min-width: 0 !important;
    margin: 0 !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-input) {
    width: 100% !important;
    min-height: 56px !important;
    padding: 1rem 1.25rem !important;
    font-size: 1.02rem !important;
    line-height: 1.2 !important;
    font-family: var(--font-sans) !important;
    border: 2px solid var(--gray-200) !important;
    border-radius: 0 !important;
    background: var(--white) !important;
    color: var(--black) !important;
    box-shadow: none !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-input::placeholder) {
    color: var(--gray-500) !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-input:focus) {
    border-color: var(--accent) !important;
    outline: none !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-submit) {
    display: inline-flex !important;
    flex: 0 0 auto !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.5rem !important;
    width: auto !important;
    min-width: 180px !important;
    min-height: 56px !important;
    padding: 0 1.5rem !important;
    font-size: 0.9rem !important;
    font-weight: 600 !important;
    font-family: var(--font-sans) !important;
    background: var(--black) !important;
    color: var(--white) !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    letter-spacing: 0.02em !important;
    white-space: nowrap !important;
    transition: background 0.2s !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-submit:hover) {
    background: var(--accent-light) !important;
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-submit span::after) {
    content: ' →';
  }

  .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-submit span) {
    white-space: nowrap !important;
  }

  @media (max-width: 640px) {
    .email-signup--default {
      padding: 3rem 0;
    }

    .email-signup--post-end {
      padding: 1.5rem;
    }

    .email-signup--default .email-signup-inner {
      padding: 0 1.25rem;
    }

    .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-fields) {
      flex-direction: column !important;
    }

    .email-signup-inner :global(.formkit-form[data-uid='41974a9f46'] .formkit-submit) {
      width: 100% !important;
      min-width: 0 !important;
    }
  }
</style>
