---
import '../styles/global.css';

const {
  title = "Zac Culpan — Thoughts on Growth, Marketing & Product",
  description = "Head of Marketing & Product. Writing about growth, ecosystem marketing, and creator strategies.",
  image = "/og-image.png",
  type = "website",
  pubDate,
  tags
} = Astro.props;

const siteUrl = Astro.site?.toString() || 'https://zacculpan.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Zac Culpan",
  "url": siteUrl,
  "jobTitle": "Head of Marketing & Product",
  "description": "Head of Marketing at Narrative, moving to Head of Product at OneRoof (NZME).",
  "sameAs": ["https://linkedin.com/in/zacculpan"]
};

const blogSchema = type === "article" ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": pubDate,
  "author": { "@type": "Person", "name": "Zac Culpan", "url": siteUrl },
  "url": canonicalURL.toString(),
  "keywords": tags?.join(", ")
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-T25CFT4G');</script>
  <!-- End Google Tag Manager -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Zac Culpan" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content={type === "article" ? "article" : "website"} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Zac Culpan" />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  {blogSchema && <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />}
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T25CFT4G"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <nav>
    <div class="container">
      <div class="nav-inner">
        <a href={import.meta.env.BASE_URL} class="nav-logo">Zac Culpan</a>
        <ul class="nav-links">
          <li><a href={`${import.meta.env.BASE_URL}blog`}>Writing</a></li>
          <li><a href={`${import.meta.env.BASE_URL}about`}>About</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <main><slot /></main>
  <footer>
    <div class="container">
      <div class="footer-inner">
        <span class="footer-name">Zac Culpan</span>
        <ul class="footer-links">
          <li><a href="/blog">Writing</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="https://linkedin.com/in/zacculpan" target="_blank" rel="noopener">LinkedIn</a></li>
        </ul>
        <span class="footer-copy">© {new Date().getFullYear()} Zac Culpan</span>
      </div>
    </div>
  </footer>
</body>
</html>