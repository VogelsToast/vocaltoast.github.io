---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailSignup from '../../components/EmailSignup.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout
  title={`${post.data.title} — Zac Culpan`}
  description={post.data.description}
  type="article"
  pubDate={post.data.pubDate.toISOString()}
  tags={post.data.tags}
  image={`/og/${post.id}.png`}
>
  <div class="container">
    <div class="post-header">
      {post.data.tags?.[0] && <span class="post-tag">{post.data.tags[0]}</span>}
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
      <div class="post-meta">
        <span>By Zac Culpan</span>
        <span>·</span>
        <span>{formatDate(post.data.pubDate)}</span>
      </div>
    </div>
    <article class="post-content">
      <Content />
    </article>
    <EmailSignup variant="post-end" />
    <div class="post-end">
      <div class="post-end-actions">
        <a
          href="https://www.linkedin.com/in/zachary-culpan/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          aria-label="Connect on LinkedIn (opens in new tab)"
        >
          Connect on LinkedIn
        </a>
        <a href={`${import.meta.env.BASE_URL}blog`} class="post-back-link">
          All writing
        </a>
      </div>
    </div>
  </div>
</BaseLayout>