---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const featuredPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const [featured, ...rest] = featuredPosts;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-headline">
        Thoughts on<br /><em>Growth,</em><br />Marketing<br />& Product.
      </h1>
      <p class="hero-sub">
        Most growth strategies are borrowed from companies that look nothing like yours. I write about what actually works — ecosystem marketing, creator-led channels, and the thinking behind growth that compounds.
      </p>
      <div class="hero-actions">
        <a href={`${import.meta.env.BASE_URL}blog`} class="btn-primary">Start reading <span class="arrow" aria-hidden="true">→</span></a>
        <a href={`${import.meta.env.BASE_URL}about`} class="btn-secondary">About Zac</a>
      </div>
    </div>
  </section>

  <!-- Writing -->
  {featuredPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="section-title">Writing</span>
          <a href={`${import.meta.env.BASE_URL}blog`} class="section-link">All essays <span class="arrow" aria-hidden="true">→</span></a>
        </div>

        <!-- Featured post -->
        {featured && (
          <a href={`${import.meta.env.BASE_URL}blog/${featured.id}`} class="post-featured">
            <div class="post-featured-meta">
              <span class="tag">{featured.data.tags?.[0] || 'Growth'}</span>
              <span>{formatDate(featured.data.pubDate)}</span>
            </div>
            <h2 class="post-featured-title">{featured.data.title}</h2>
            <p class="post-featured-excerpt">{featured.data.description}</p>
            <span class="post-featured-cta">Read this essay <span class="arrow" aria-hidden="true">→</span></span>
          </a>
        )}

        <!-- Secondary posts -->
        {rest.length > 0 && (
          <div class="post-mini-list">
            {rest.map((post) => (
              <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} class="post-mini">
                <div class="post-mini-date">{formatDate(post.data.pubDate)}</div>
                <div>
                  <span class="post-mini-tag">{post.data.tags?.[0] || 'Growth'}</span>
                  <h3 class="post-mini-title">{post.data.title}</h3>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- About Strip -->
  <section class="about-strip">
    <div class="container">
      <div class="about-inner">
        <div>
          <img
            src={`${import.meta.env.BASE_URL}zac-headshot-final.jpg`}
            alt="Zac Culpan"
            class="about-headshot"
            width="140"
            height="140"
          />
          <h2 class="about-name">Zac Culpan</h2>
        </div>
        <div>
          <p class="about-text">
            I've spent my career at the intersection of marketing and product — figuring out what makes growth stick. Currently Head of Marketing at <strong>Narrative</strong>, moving to Head of Product at <strong>OneRoof (NZME)</strong>.
          </p>
          <p class="about-text">
            On the side, I'm building a startup focused on ecosystem and creator marketing — helping companies grow through communities, partnerships, and creator-led channels rather than paid acquisition alone.
          </p>
          <div class="about-roles">
            <span class="role-badge">Ecosystem Marketing</span>
            <span class="role-badge">Creator Marketing</span>
            <span class="role-badge">SaaS Growth</span>
            <span class="role-badge">Product Strategy</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
